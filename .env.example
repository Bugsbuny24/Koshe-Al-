# Copy to .env and fill in values
# PostgreSQL
POSTGRES_USER=adgenius
POSTGRES_PASSWORD=adgenius
POSTGRES_DB=adgenius
DATABASE_URL=postgresql+asyncpg://adgenius:adgenius@localhost:5432/adgenius

# Redis
REDIS_URL=redis://localhost:6379

# Security - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret

# Gemini API (leave empty to use mock responses in development)
GEMINI_API_KEY=

# Environment
ENVIRONMENT=development

# Feature Flags (all disabled in V1)
ENABLE_TIKTOK_CONNECT=false
ENABLE_META_CONNECT=false
ENABLE_GOOGLE_CONNECT=false
ENABLE_PUBLISHING=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
